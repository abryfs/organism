#!/bin/bash
set -e

echo "Setting up Organism v$(cat "$(dirname "$0")/VERSION" | tr -d '[:space:]')..."

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
SETTINGS_FILE="$HOME/.claude/settings.json"

# Check Claude Code
if ! command -v claude &> /dev/null; then
    echo "Warning: Claude Code CLI not found. Install from https://claude.ai/claude-code"
fi

# Register SessionStart hook for auto-update check
if [ -f "$SETTINGS_FILE" ]; then
    HOOK_CMD="$SCRIPT_DIR/bin/check-update.sh"
    if ! grep -q "check-update.sh" "$SETTINGS_FILE" 2>/dev/null; then
        echo ""
        echo "To enable auto-update checks, add this to your SessionStart hooks in $SETTINGS_FILE:"
        echo ""
        echo '  "SessionStart": [{ "hooks": [{ "type": "command", "command": "'"$HOOK_CMD"'", "timeout": 10 }] }]'
        echo ""
    fi
fi

# Agent Teams (optional)
if [ -f "$SETTINGS_FILE" ]; then
    if ! grep -q "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS" "$SETTINGS_FILE" 2>/dev/null; then
        echo "Agent Teams not enabled. /organism:split is optional — enable with:"
        echo '  "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" }'
        echo ""
    fi
fi

# Optional dependencies
echo "Dependencies (all optional):"
if command -v gsd 2>/dev/null || [ -d "$HOME/.claude/get-shit-done" ]; then
    echo "  GSD: found"
else
    echo "  GSD: not found"
fi

if [ -d "$HOME/.claude/plugins/cache/claude-plugins-official/superpowers" ] 2>/dev/null; then
    echo "  Superpowers: found"
else
    echo "  Superpowers: not found"
fi

if [ -d "$HOME/.claude/skills/gstack" ]; then
    echo "  gstack: found"
else
    echo "  gstack: not found"
fi

VERSION=$(cat "$SCRIPT_DIR/VERSION" | tr -d '[:space:]')
echo ""
echo "Organism $VERSION ready."
echo ""
echo "  /organism              — Start (auto-detects mode)"
echo "  /organism:north-star   — Define product purpose"
echo "  /organism:demand       — Research market demand"
echo "  /organism:competitive  — Scan competitors"
echo "  /organism:interview    — Prep/capture user interviews"
echo "  /organism:feedback     — Process user feedback"
echo "  /organism:reality-check — Validate against reality"
echo "  /organism:user-lens    — Test from user perspectives"
echo "  /organism:health-check — Product status pulse"
echo "  /organism:sync-check   — Docs/code consistency"
echo "  /organism:split        — 3-agent mode (Agent Teams)"
echo "  /organism:update       — Check for updates"
echo ""
