#!/bin/bash
set -e

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
VERSION=$(cat "$SCRIPT_DIR/VERSION" | tr -d '[:space:]')

echo "Setting up Organism v${VERSION}..."
echo ""

# Check Claude Code
if ! command -v claude &> /dev/null; then
    echo "ERROR: Claude Code CLI not found."
    echo "Install from: https://claude.ai/claude-code"
    exit 1
fi

# ── Install Organs ──────────────────────────────────────

MISSING=0

# Brain (GSD)
echo "Checking Brain (GSD)..."
if command -v gsd 2>/dev/null || [ -d "$HOME/.claude/get-shit-done" ]; then
    echo "  Brain: installed"
else
    echo "  Brain: not found. Installing GSD..."
    npx get-shit-done-cc 2>/dev/null || {
        echo ""
        echo "  Could not auto-install GSD. Install manually:"
        echo "    npx get-shit-done-cc"
        echo ""
        MISSING=$((MISSING + 1))
    }
fi

# Spine (Superpowers)
echo "Checking Spine (Superpowers)..."
if [ -d "$HOME/.claude/plugins/cache/claude-plugins-official/superpowers" ]; then
    echo "  Spine: installed"
else
    echo "  Spine: not found."
    echo "  Install via Claude Code: /plugins then enable 'superpowers'"
    echo ""
    MISSING=$((MISSING + 1))
fi

# Hands (gstack)
echo "Checking Hands (gstack)..."
if [ -d "$HOME/.claude/skills/gstack" ]; then
    echo "  Hands: installed"
else
    echo "  Hands: not found. Installing gstack..."
    if [ -d "$HOME/.claude/skills" ]; then
        git clone https://github.com/garrytan/gstack.git "$HOME/.claude/skills/gstack" 2>/dev/null && {
            cd "$HOME/.claude/skills/gstack" && ./setup 2>/dev/null
            echo "  Hands: installed"
        } || {
            echo "  Could not auto-install gstack. Install manually:"
            echo "    git clone https://github.com/garrytan/gstack.git ~/.claude/skills/gstack"
            echo "    cd ~/.claude/skills/gstack && ./setup"
            echo ""
            MISSING=$((MISSING + 1))
        }
    fi
fi

echo ""

if [ $MISSING -gt 0 ]; then
    echo "WARNING: $MISSING organ(s) missing. Organism works best with all three."
    echo "Install the missing organs above, then re-run ./setup"
    echo ""
fi

# ── Agent Teams (for /split) ───────────────────────────

SETTINGS_FILE="$HOME/.claude/settings.json"
if [ -f "$SETTINGS_FILE" ]; then
    if ! grep -q "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS" "$SETTINGS_FILE" 2>/dev/null; then
        echo "Agent Teams not enabled (optional — needed for /organism:split)."
        echo "  Add to $SETTINGS_FILE:"
        echo '  "env": { "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1" }'
        echo ""
    fi
fi

# ── Auto-update hook ───────────────────────────────────

if [ -f "$SETTINGS_FILE" ]; then
    HOOK_CMD="$SCRIPT_DIR/bin/check-update.sh"
    if ! grep -q "check-update.sh" "$SETTINGS_FILE" 2>/dev/null; then
        echo "To enable auto-update checks, add to SessionStart hooks:"
        echo "  \"command\": \"$HOOK_CMD\""
        echo ""
    fi
fi

# ── Done ───────────────────────────────────────────────

echo "Organism v${VERSION} ready."
echo ""
echo "  /organism              — Start (auto-detects mode)"
echo "  /organism:north-star   — Define product purpose"
echo "  /organism:demand       — Research market demand"
echo "  /organism:competitive  — Scan competitors"
echo "  /organism:interview    — Prep/capture user interviews"
echo "  /organism:feedback     — Process user feedback"
echo "  /organism:reality-check — Validate against reality"
echo "  /organism:user-lens    — Test from user perspectives"
echo "  /organism:health-check — Product status pulse"
echo "  /organism:sync-check   — Docs/code consistency"
echo "  /organism:split        — 3-agent mode (Agent Teams)"
echo "  /organism:update       — Check for updates"
echo ""
